<navigation-bar title="生词本" color="#172033" background="#F7F8FA"></navigation-bar>

<view class="page">
  <view class="summary">
    <text class="title">待复习</text>
    <text class="subtitle">{{languageName}} · 本地保存 {{words.length}} 个生词</text>
  </view>

  <view class="stats-panel">
    <view class="stat">
      <text class="number blue">{{words.length}}</text>
      <text class="label">生词</text>
    </view>
    <view class="stat">
      <text class="number orange">{{words.length - learnedCount}}</text>
      <text class="label">今日复习</text>
    </view>
    <view class="stat">
      <text class="number green">{{words.length ? learnedCount : 0}}</text>
      <text class="label">已掌握</text>
    </view>
  </view>

  <view wx:if="{{words.length > 0}}" class="toolbar">
    <input class="search" placeholder="搜索生词 / 中文释义" value="{{keyword}}" bindinput="onSearch" />
    <button wx:if="{{keyword}}" class="clear-button" bindtap="clearSearch">清空</button>
  </view>

  <view wx:if="{{words.length > 0}}" class="action-row">
    <button class="review-button" bindtap="goReview">复习生词</button>
    <button class="learn-button small" bindtap="goWords">继续学习</button>
  </view>

  <view wx:if="{{visibleWords.length > 0}}" class="word-list">
    <view wx:for="{{visibleWords}}" wx:key="id" class="word-card">
      <view class="word-main" data-id="{{item.id}}" bindtap="goDetail">
        <view class="word-row">
          <text class="word">{{item.word}}</text>
          <text wx:if="{{item.isLearned}}" class="status learned">已掌握</text>
          <text wx:else class="status">今天</text>
        </view>
        <text class="pronunciation">{{item.pronunciation}}</text>
        <text class="meaning">{{item.meaning}}</text>
      </view>
      <button class="remove" data-id="{{item.id}}" bindtap="removeFavorite">移除</button>
    </view>
  </view>

  <view wx:elif="{{words.length > 0}}" class="empty">
    <text class="empty-title">没有找到匹配的生词</text>
    <text class="empty-subtitle">换个关键词试试，或者清空搜索。</text>
    <button class="learn-button" bindtap="clearSearch">清空搜索</button>
  </view>

  <view wx:else class="empty">
    <text class="empty-title">还没有生词</text>
    <text class="empty-subtitle">在单词详情页点击“加入生词本”后会显示在这里。</text>
    <button class="learn-button" bindtap="goWords">去学习</button>
  </view>
</view>
