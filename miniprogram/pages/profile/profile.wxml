<navigation-bar title="我的" back="{{false}}" color="#172033" background="#F7F8FA"></navigation-bar>

<scroll-view class="page-scroll" scroll-y type="list">
  <view class="page">
    <view class="profile-head">
      <text class="avatar">{{avatarText}}</text>
      <view>
        <text class="title">Dawn</text>
        <text class="subtitle">本地学习数据 · 自用版</text>
        <text class="subtitle">{{language.name}} {{language.level}} · AI 后端{{backendStatus}}</text>
      </view>
    </view>

    <view class="weekly-panel">
      <text class="section-title">本周学习</text>
      <view class="stats-grid">
        <view class="stat">
          <text class="number blue">{{stats.learned}}</text>
          <text class="label">已学</text>
        </view>
        <view class="stat">
          <text class="number green">{{stats.favorites}}</text>
          <text class="label">生词</text>
        </view>
        <view class="stat">
          <text class="number orange">{{stats.reviewed}}</text>
          <text class="label">复习</text>
        </view>
      </view>
    </view>

    <view class="progress-card">
      <view class="progress-head">
        <text class="section-title">当前词库进度</text>
        <text class="progress-number">{{progressPercent}}%</text>
      </view>
      <view class="progress-track">
        <view class="progress-fill" style="width: {{progressPercent}}%;"></view>
      </view>
      <text class="progress-text">{{stats.learned}} / {{stats.total}} 个词已掌握</text>
    </view>

    <view class="menu">
      <view class="menu-item" bindtap="goLanguage">
        <text>学习进度</text>
        <text class="value">{{language.name}} {{language.level}}</text>
      </view>
      <view class="menu-item" bindtap="exportData">
        <text>导出学习数据</text>
        <text class="value">复制 JSON</text>
      </view>
      <view class="menu-item" bindtap="confirmClearChat">
        <text>清空 AI 对话</text>
        <text class="value">{{chatCount}} 条</text>
      </view>
      <view class="menu-item danger" bindtap="confirmClear">
        <text>清空本地学习数据</text>
        <text class="value">谨慎操作</text>
      </view>
    </view>

    <view class="quick-grid">
      <button class="quick primary" bindtap="goWords">继续学习</button>
      <button class="quick" bindtap="goReview">开始复习</button>
      <button class="quick" bindtap="goChat">AI 对话</button>
      <button class="quick" bindtap="goVocab">生词本</button>
    </view>
  </view>
</scroll-view>
