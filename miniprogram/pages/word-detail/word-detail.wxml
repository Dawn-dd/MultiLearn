<navigation-bar title="单词详情" color="#30233D" background="#FFF9FC"></navigation-bar>

<scroll-view wx:if="{{word}}" class="page-scroll" scroll-y type="list">
  <view class="page candy-page">
    <image class="candy-bg-image bg-lollipop" src="/assets/candy/lollipop.png" mode="aspectFit"></image>
    <image class="detail-star" src="/assets/candy/star.png" mode="aspectFit"></image>

    <view class="word-panel">
      <view class="top-row">
        <text class="level">{{word.level}}</text>
        <text class="state {{word.isLearned ? 'learned' : ''}}">{{statusText}}</text>
      </view>
      <view class="apple-badge {{detailAsset ? 'with-asset' : ''}}">
        <image class="badge-gloss" src="/assets/candy/candy-ball.png" mode="aspectFit"></image>
        <image wx:if="{{detailAsset}}" class="detail-asset" src="{{detailAsset}}" mode="aspectFit"></image>
        <text wx:else>{{detailInitial}}</text>
      </view>
      <text class="word" bindtap="copyWord">{{word.word}}</text>
      <text class="pronunciation">{{word.pronunciation}}</text>
      <button class="sound-button" bindtap="playAudio">发音</button>
      <text class="meaning-main">{{word.meaning}}</text>
    </view>

    <view class="section">
      <text class="section-title">词卡信息</text>
      <view class="info-grid">
        <view class="info-item">
          <text class="info-label">词性</text>
          <text class="info-value">{{partOfSpeechText}}</text>
        </view>
        <view class="info-item">
          <text class="info-label">上次复习</text>
          <text class="info-value">{{reviewText}}</text>
        </view>
        <view class="info-item wide">
          <text class="info-label">下次复习</text>
          <text class="info-value">{{nextReviewText}}</text>
        </view>
      </view>
    </view>

    <view class="section">
      <text class="section-title">例句</text>
      <view class="card">
        <view class="card-head">
          <text class="card-label">Example</text>
          <button class="mini-sound" bindtap="playAudio">发音</button>
        </view>
        <text class="example">{{word.example}}</text>
        <text class="example-meaning">{{word.exampleMeaning}}</text>
      </view>
    </view>

    <view class="section">
      <text class="section-title">标签</text>
      <view class="tag-row">
        <text wx:for="{{word.tags}}" wx:key="*this" class="tag">{{item}}</text>
      </view>
    </view>

    <view wx:if="{{aiAnswer}}" class="ai-result">
      <text class="section-title">AI 解释</text>
      <text class="ai-answer">{{aiAnswer}}</text>
    </view>

    <view class="actions">
      <button class="action vocab {{word.isFavorite ? 'active' : ''}}" bindtap="toggleFavorite">{{favoriteText}}</button>
      <button class="action known" bindtap="markKnown">认识</button>
      <button class="action unknown" bindtap="markUnknown">不认识</button>
      <button class="action ai" loading="{{aiLoading}}" bindtap="askAi">AI 解释</button>
    </view>

    <button class="next-button" bindtap="goNextWord">下一个单词</button>
  </view>
</scroll-view>

<view wx:else class="empty candy-page">
  <text class="empty-title">没有找到这个单词</text>
  <text class="empty-subtitle">可能是切换了语言，或词库数据被调整。</text>
  <button class="empty-button" bindtap="goWords">回单词列表</button>
</view>
