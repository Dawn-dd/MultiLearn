<navigation-bar title="单词详情" color="#172033" background="#F7F8FA"></navigation-bar>

<scroll-view wx:if="{{word}}" class="page-scroll" scroll-y type="list">
  <view class="page">
    <view class="word-panel">
      <view class="top-row">
        <text class="level">{{word.level}}</text>
        <text class="state {{word.isLearned ? 'learned' : ''}}">{{statusText}}</text>
      </view>
      <text class="word" bindtap="copyWord">{{word.word}}</text>
      <text class="pronunciation">{{word.pronunciation}}</text>
      <view class="action-row">
        <button class="small-button primary" bindtap="playAudio">播放发音</button>
        <button class="small-button dark" bindtap="toggleFavorite">{{favoriteText}}</button>
      </view>
    </view>

    <view class="section">
      <text class="section-title">释义</text>
      <view class="card">
        <text class="meaning">{{word.meaning}}</text>
      </view>
    </view>

    <view class="section">
      <text class="section-title">例句</text>
      <view class="card">
        <text class="example">{{word.example}}</text>
        <text class="example-meaning">{{word.exampleMeaning}}</text>
        <text class="ai-hint" bindtap="askAi">AI 可继续生成更多例句和对话练习</text>
      </view>
    </view>

    <view class="status-panel">
      <view class="status-item">
        <text class="status-label">生词本</text>
        <text class="status-value">{{word.isFavorite ? '已加入' : '未加入'}}</text>
      </view>
      <view class="status-item">
        <text class="status-label">复习次数</text>
        <text class="status-value">{{word.reviewCount}}</text>
      </view>
      <view class="status-item">
        <text class="status-label">上次复习</text>
        <text class="status-value">{{reviewText}}</text>
      </view>
    </view>

    <view class="actions">
      <button class="action primary {{word.isLearned ? 'done' : ''}}" bindtap="markLearned">{{word.isLearned ? '已掌握' : '标记掌握'}}</button>
      <button class="action" bindtap="askAi">问 AI</button>
      <button class="action" bindtap="goNextWord">下一个</button>
    </view>
  </view>
</scroll-view>

<view wx:else class="empty">
  <text class="empty-title">没有找到这个单词</text>
  <text class="empty-subtitle">可能是切换了语言，或者词库数据被调整。</text>
  <button class="empty-button" bindtap="goWords">回单词列表</button>
</view>
