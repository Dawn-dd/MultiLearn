<navigation-bar title="复习" back="{{false}}" color="#30233D" background="#FFF9FC"></navigation-bar>

<view class="page candy-page">
  <view class="top-line">
    <view>
      <text class="title">复习卡片</text>
      <text class="source">{{sourceText}}</text>
    </view>
    <text class="counter">{{completed ? reviewWords.length : currentIndex + 1}} / {{reviewWords.length}}</text>
  </view>

  <view class="progress-track">
    <view class="progress-fill" style="width: {{progressPercent}}%;"></view>
  </view>

  <view wx:if="{{currentWord && !completed}}" class="card" bindtap="toggleAnswer">
    <view class="stripe"></view>
    <view class="star">★</view>
    <view class="card-head">
      <text class="hint">{{showAnswer ? '释义与例句' : '点击卡片查看答案'}}</text>
      <text class="tag">{{currentWord.isFavorite ? '生词' : currentWord.level}}</text>
    </view>
    <text class="word">{{currentWord.word}}</text>
    <text class="pronunciation">{{currentWord.pronunciation}}</text>

    <view wx:if="{{showAnswer}}" class="answer">
      <text class="meaning">{{currentWord.meaning}}</text>
      <text class="example">{{currentWord.example}}</text>
      <text class="example-meaning">{{currentWord.exampleMeaning}}</text>
    </view>
    <text wx:else class="tap-hint">点击查看释义</text>
  </view>

  <view wx:if="{{currentWord && !completed}}" class="actions">
    <button class="action weak" bindtap="markDifficult">不认识</button>
    <button class="action strong" bindtap="markRemembered">认识</button>
  </view>

  <button wx:if="{{currentWord && !completed}}" class="detail-button" bindtap="goDetail">查看详情</button>

  <view wx:if="{{completed && !isEmpty}}" class="done">
    <text class="done-icon">✓</text>
    <text class="done-title">这一轮复习完成</text>
    <text class="done-subtitle">认识 {{rememberedCount}} 个，不认识 {{difficultCount}} 个。</text>
    <view class="done-actions">
      <button class="restart" bindtap="restart">再复习一轮</button>
      <button class="secondary" bindtap="goWords">继续学习</button>
    </view>
  </view>

  <view wx:if="{{isEmpty}}" class="done">
    <text class="done-icon">?</text>
    <text class="done-title">还没有可复习的单词</text>
    <text class="done-subtitle">先去单词列表学习，或者把难词加入生词本。</text>
    <view class="done-actions">
      <button class="restart" bindtap="goWords">去学习</button>
      <button class="secondary" bindtap="goVocab">看生词本</button>
    </view>
  </view>
</view>
